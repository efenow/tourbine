<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — Tourbine</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/style.css">
  <%- typeof extraHead !== 'undefined' ? extraHead : '' %>
</head>
<body>
<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
  <div class="container">
    <a class="navbar-brand fw-bold" href="/"><i class="bi bi-globe"></i> Tourbine</a>
    <div class="navbar-nav ms-auto align-items-center">
      <a class="nav-link" href="/">Tours</a>
      <a class="nav-link" href="/dashboard"><i class="bi bi-grid"></i> Dashboard</a>
      <% if (currentUser) { %>
        <span class="navbar-text text-light small me-2">
          <i class="bi bi-person-circle"></i> <%= currentUser.username %> (<%= currentUser.role %>)
        </span>
        <form action="/dashboard/logout" method="POST" class="d-inline">
          <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
          <button type="submit" class="btn btn-outline-light btn-sm">
            <i class="bi bi-box-arrow-right"></i> Logout
          </button>
        </form>
      <% } else { %>
        <a class="btn btn-outline-light btn-sm ms-2" href="/dashboard/login">
          <i class="bi bi-box-arrow-in-right"></i> Login
        </a>
      <% } %>
    </div>
  </div>
</nav>
