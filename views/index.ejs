<%- include('partials/header', { title, extraHead: '' }) %>
<main class="container py-5">
  <% const canEdit = currentUser && (currentUser.role === 'admin' || currentUser.role === 'system_admin'); %>
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h2 mb-0">Virtual Tours</h1>
    <% if (canEdit) { %>
      <a href="/dashboard/tours/new" class="btn btn-primary"><i class="bi bi-plus-lg"></i> New Tour</a>
    <% } %>
  </div>

  <% if (tours.length === 0) { %>
    <div class="card text-center py-5">
      <div class="card-body">
        <i class="bi bi-camera-video display-4 text-muted mb-3 d-block"></i>
        <p class="text-muted mb-3">No tours yet.<% if (canEdit) { %> Create one in the Dashboard.<% } %></p>
        <% if (canEdit) { %>
          <a href="/dashboard/tours/new" class="btn btn-primary">Create Your First Tour</a>
        <% } %>
      </div>
    </div>
  <% } else { %>
    <div class="row row-cols-1 row-cols-md-3 g-4">
      <% for (const tour of tours) { %>
        <div class="col">
          <div class="card h-100 tour-card">
            <% if (tour.cover_image) { %>
              <img src="/<%= tour.cover_image %>" class="card-img-top" style="height:200px;object-fit:cover" alt="<%= tour.name %>">
            <% } else { %>
              <div class="cover-placeholder">
                <i class="bi bi-arrow-repeat display-3 text-secondary"></i>
              </div>
            <% } %>
            <div class="card-body">
              <h5 class="card-title"><%= tour.name %></h5>
              <% if (tour.description) { %>
                <p class="card-text text-muted"><%= tour.description %></p>
              <% } %>
              <small class="text-muted"><%= tour.room_count %> room(s)</small>
            </div>
            <div class="card-footer d-flex gap-2">
              <a href="/tour/<%= tour.slug %>" class="btn btn-primary btn-sm">View Tour</a>
              <% if (canEdit) { %>
                <a href="/dashboard/tours/<%= tour.id %>/rooms" class="btn btn-outline-secondary btn-sm">Edit</a>
              <% } %>
            </div>
          </div>
        </div>
      <% } %>
    </div>
  <% } %>
</main>
<%- include('partials/footer', {}) %>
