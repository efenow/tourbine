<%
  const extraHeadParts = ['<link rel="stylesheet" href="/css/pannellum-picker.css">'];
  const rawRoomImagePath = room && room.image_path
    ? String(room.image_path).replace(/\\/g, '/')
    : '';
  const safeRoomImagePath = /^uploads\/[a-f0-9]{24}\.(?:jpe?g|png|webp)$/i.test(rawRoomImagePath) ? rawRoomImagePath : '';
  if (safeRoomImagePath) {
    extraHeadParts.unshift('<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/pannellum@2.5.6/build/pannellum.css">');
  }
%>
<%- include('../partials/header', { title, extraHead: extraHeadParts.join('') }) %>
<main class="container py-5">
  <nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
      <li class="breadcrumb-item"><a href="/dashboard/tours/<%= tour.id %>/rooms"><%= tour.name %></a></li>
      <li class="breadcrumb-item active"><%= room ? room.name : 'New Room' %></li>
    </ol>
  </nav>

  <div class="card mx-auto" style="max-width: 700px;">
    <div class="card-header">
      <h5 class="mb-0"><%= room ? 'Edit Room' : 'New Room' %></h5>
    </div>
    <div class="card-body">
      <% if (error) { %>
        <div class="alert alert-danger"><%= error %></div>
      <% } %>
      <form method="POST" enctype="multipart/form-data"
            action="<%= room
              ? `/dashboard/tours/${tour.id}/rooms/${room.id}?_method=PUT&_csrf=${encodeURIComponent(csrfToken)}`
              : `/dashboard/tours/${tour.id}/rooms?_csrf=${encodeURIComponent(csrfToken)}` %>">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="mb-3">
          <label for="name" class="form-label">Room Name <span class="text-danger">*</span></label>
          <input type="text" id="name" name="name" class="form-control" required
                 value="<%= room ? room.name : '' %>" placeholder="e.g. Entrance Hall">
        </div>

        <div class="mb-3">
          <label for="image" class="form-label">Photo Sphere Image</label>
          <% if (safeRoomImagePath) { %>
            <div class="mb-2">
              <img src="/<%= safeRoomImagePath %>" class="img-thumbnail" style="max-height:120px;" alt="Current image">
              <div class="text-muted small mt-1">Current image — upload a new one to replace it</div>
            </div>
          <% } %>
          <input type="file" id="image" name="image" class="form-control"
                 accept="image/jpeg,image/png,image/webp">
          <div class="form-text">JPEG, PNG, or WebP. Max 100 MB. Use an equirectangular (2:1) image for best results.</div>
        </div>

        <div class="mb-3">
          <label class="form-label">Privacy Tools</label>
          <div id="privacy-editor-empty" class="privacy-editor-empty">
            Select an image to enable blur and mosaic tools.
          </div>
          <div id="privacy-editor-root" class="privacy-editor-root" style="display:none;">
            <div class="privacy-editor-toolbar">
              <div class="btn-group btn-group-sm" role="group" aria-label="Privacy tools">
                <button type="button" class="btn btn-outline-secondary active" id="privacy-tool-blur">
                  <i class="bi bi-droplet-half"></i> Blur
                </button>
                <button type="button" class="btn btn-outline-secondary" id="privacy-tool-mosaic">
                  <i class="bi bi-grid-3x3-gap"></i> Mosaic
                </button>
              </div>
              <label class="small mb-0">
                Brush
                <input type="range" id="privacy-brush-size" min="20" max="260" value="90">
              </label>
              <label class="small mb-0">
                Strength
                <input type="range" id="privacy-tool-strength" min="4" max="40" value="14">
              </label>
              <button type="button" class="btn btn-sm btn-outline-danger ms-auto" id="privacy-reset-btn">
                <i class="bi bi-arrow-counterclockwise"></i> Reset
              </button>
            </div>
            <div class="privacy-editor-canvas-wrap">
              <canvas id="privacy-editor-canvas"></canvas>
            </div>
            <div class="form-text">
              Drag on the image to apply the selected effect. Saving the room will upload the edited image.
            </div>
          </div>
        </div>

        <div class="row g-3 mb-2">
          <div class="col">
            <label for="initial_pitch" class="form-label">Initial Pitch</label>
            <input type="number" id="initial_pitch" name="initial_pitch" class="form-control"
                   min="-90" max="90" step="0.1" value="<%= room ? room.initial_pitch : 0 %>">
            <div class="form-text">Vertical angle (-90 to 90)</div>
          </div>
          <div class="col">
            <label for="initial_yaw" class="form-label">Initial Yaw</label>
            <input type="number" id="initial_yaw" name="initial_yaw" class="form-control"
                   min="-180" max="180" step="0.1" value="<%= room ? room.initial_yaw : 0 %>">
            <div class="form-text">Horizontal angle (-180 to 180)</div>
          </div>
        </div>

        <% if (safeRoomImagePath) { %>
        <!-- 360° preview for setting initial pitch/yaw -->
        <div class="mb-3">
          <button type="button" class="btn btn-sm btn-outline-secondary mb-2" id="toggle-preview-btn">
            <i class="bi bi-camera"></i> Set initial view from panorama
          </button>
          <div id="preview-section" style="display:none;">
            <div id="pnlm-preview" class="mb-2"></div>
            <div class="d-flex align-items-center gap-2">
              <span class="text-muted small"><i class="bi bi-arrows-move"></i> Drag to navigate — the crosshair marks the center</span>
              <button type="button" class="btn btn-sm btn-success ms-auto" id="capture-initial-btn">
                <i class="bi bi-check-lg"></i> Use this view
              </button>
            </div>
          </div>
        </div>
        <% } %>

        <div class="mb-3 form-check">
          <input type="checkbox" id="is_default" name="is_default" class="form-check-input"
                 <%= room && room.is_default ? 'checked' : '' %>>
          <label for="is_default" class="form-check-label">Set as default room</label>
        </div>

        <div class="d-flex gap-2">
          <button type="submit" class="btn btn-primary">
            <i class="bi bi-check-lg"></i> <%= room ? 'Save Changes' : 'Create Room' %>
          </button>
          <a href="/dashboard/tours/<%= tour.id %>/rooms" class="btn btn-outline-secondary">Cancel</a>
        </div>
      </form>
    </div>
  </div>

  <% if (room) { %>
    <div class="card mx-auto mt-4" style="max-width: 700px;">
      <div class="card-header">
        <h5 class="mb-0"><i class="bi bi-arrow-right-circle"></i> Hotspots</h5>
      </div>
      <div class="card-body">
        <% if (hotspots.length === 0) { %>
          <p class="text-muted small">No hotspots yet.</p>
        <% } else { %>
          <ul class="list-group list-group-flush mb-3">
            <% for (const hs of hotspots) { %>
              <li class="list-group-item">
                <div class="d-flex flex-wrap gap-2 align-items-end">
                  <form action="/dashboard/hotspots/<%= hs.id %>?_method=PUT" method="POST" class="row g-2 align-items-end flex-grow-1">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <div class="col-12 col-md-3">
                      <label class="form-label small">To Room</label>
                      <select name="to_room_id" class="form-select form-select-sm" required>
                        <% for (const r of allRooms) { %>
                          <option value="<%= r.id %>" <%= r.id === hs.to_room_id ? 'selected' : '' %>><%= r.name %></option>
                        <% } %>
                      </select>
                    </div>
                    <div class="col-6 col-md-2">
                      <label class="form-label small">Pitch</label>
                      <input type="number" name="pitch" class="form-control form-control-sm"
                             value="<%= hs.pitch %>" step="0.1" min="-90" max="90">
                    </div>
                    <div class="col-6 col-md-2">
                      <label class="form-label small">Yaw</label>
                      <input type="number" name="yaw" class="form-control form-control-sm"
                             value="<%= hs.yaw %>" step="0.1" min="-180" max="180">
                    </div>
                    <div class="col-12 col-md-3">
                      <label class="form-label small">Label</label>
                      <input type="text" name="text" class="form-control form-control-sm"
                             value="<%= hs.text %>" placeholder="Optional label">
                    </div>
                    <div class="col-12 col-md-2">
                      <button type="submit" class="btn btn-outline-primary btn-sm w-100"><i class="bi bi-check2"></i> Update</button>
                    </div>
                  </form>
                  <form action="/dashboard/hotspots/<%= hs.id %>?_method=DELETE" method="POST"
                        onsubmit="return confirm('Delete this hotspot?')">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button type="submit" class="btn btn-outline-danger btn-sm"><i class="bi bi-trash"></i></button>
                  </form>
                </div>
              </li>
            <% } %>
          </ul>
        <% } %>

        <% if (allRooms.length > 0) { %>
          <hr>
          <h6>Add Hotspot</h6>
          <form method="POST" action="/dashboard/tours/<%= tour.id %>/rooms/<%= room.id %>/hotspots" id="add-hotspot-form">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <div class="mb-2">
              <label class="form-label small">Link to Room</label>
              <select name="to_room_id" class="form-select form-select-sm" required>
                <option value="">Select a room…</option>
                <% for (const r of allRooms) { %>
                  <option value="<%= r.id %>"><%= r.name %></option>
                <% } %>
              </select>
            </div>
            <div class="row g-2 mb-2">
              <div class="col">
                <label class="form-label small">Pitch</label>
                <input type="number" name="pitch" id="hs-pitch" class="form-control form-control-sm" value="0" step="0.1" min="-90" max="90">
              </div>
              <div class="col">
                <label class="form-label small">Yaw</label>
                <input type="number" name="yaw" id="hs-yaw" class="form-control form-control-sm" value="0" step="0.1" min="-180" max="180">
              </div>
            </div>
            <% if (safeRoomImagePath) { %>
            <div class="mb-2">
              <button type="button" class="btn btn-sm btn-outline-secondary" id="toggle-picker-btn">
                <i class="bi bi-crosshair"></i> Pick position from panorama
              </button>
              <div id="picker-section" style="display:none;" class="mt-2">
                <div id="pnlm-hotspot-picker" class="mb-2"></div>
                <div class="d-flex align-items-center gap-2">
                  <span class="text-muted small"><i class="bi bi-arrows-move"></i> Aim the crosshair at the hotspot position</span>
                  <button type="button" class="btn btn-sm btn-success ms-auto" id="capture-hs-btn">
                    <i class="bi bi-check-lg"></i> Use crosshair position
                  </button>
                </div>
              </div>
            </div>
            <% } %>
            <div class="mb-2">
              <label class="form-label small">Label (optional)</label>
              <input type="text" name="text" class="form-control form-control-sm" placeholder="e.g. Go to kitchen">
            </div>
            <button type="submit" class="btn btn-sm btn-primary"><i class="bi bi-plus-lg"></i> Add Hotspot</button>
          </form>
        <% } else { %>
          <p class="text-muted small mt-2">Add more rooms to this tour to create hotspots.</p>
        <% } %>
      </div>
    </div>
  <% } %>
</main>

<script>
  (() => {
    const imageInput = document.getElementById('image');
    const editorRoot = document.getElementById('privacy-editor-root');
    const editorEmpty = document.getElementById('privacy-editor-empty');
    const canvas = document.getElementById('privacy-editor-canvas');
    const blurBtn = document.getElementById('privacy-tool-blur');
    const mosaicBtn = document.getElementById('privacy-tool-mosaic');
    const brushSizeInput = document.getElementById('privacy-brush-size');
    const strengthInput = document.getElementById('privacy-tool-strength');
    const resetBtn = document.getElementById('privacy-reset-btn');
    const form = imageInput ? imageInput.closest('form') : null;

    if (!imageInput || !editorRoot || !canvas || !form) return;

    const existingImageUrl = <%- JSON.stringify(safeRoomImagePath ? ('/' + safeRoomImagePath) : '') %>;
    const ctx = canvas.getContext('2d', { willReadFrequently: true });
    const sourceCanvas = document.createElement('canvas');
    const sourceCtx = sourceCanvas.getContext('2d');
    const tempCanvas = document.createElement('canvas');
    const tempCtx = tempCanvas.getContext('2d');

    const MAX_EDIT_WIDTH = 4096;
    // 0.92 keeps panoramic details visually sharp while still reducing upload size vs. lossless output.
    const OUTPUT_JPEG_QUALITY = 0.92;
    const EDITED_FILE_SUFFIX = '-edited';
    const supportsEditedUpload = typeof DataTransfer !== 'undefined' && typeof File !== 'undefined';
    let tool = 'blur';
    let painting = false;
    let hasImage = false;
    let dirty = false;
    let objectUrl = null;

    function setTool(nextTool) {
      tool = nextTool;
      blurBtn.classList.toggle('active', tool === 'blur');
      mosaicBtn.classList.toggle('active', tool === 'mosaic');
    }

    function setEditorVisible(visible) {
      editorRoot.style.display = visible ? 'block' : 'none';
      editorEmpty.style.display = visible ? 'none' : 'block';
    }

    function clamp(value, min, max) {
      return Math.min(max, Math.max(min, value));
    }

    function sanitizeFilename(name) {
      return String(name || '')
        .replace(/\.[a-z0-9]+$/i, '')
        .replace(/[^a-z0-9_-]+/gi, '-')
        .replace(/^-+|-+$/g, '') || 'room-image';
    }

    function getCanvasPoint(evt) {
      const rect = canvas.getBoundingClientRect();
      const x = (evt.clientX - rect.left) * (canvas.width / rect.width);
      const y = (evt.clientY - rect.top) * (canvas.height / rect.height);
      return { x, y };
    }

    function renderFromSource() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      ctx.drawImage(sourceCanvas, 0, 0);
    }

    function loadImage(img) {
      let targetWidth = img.naturalWidth || img.width;
      let targetHeight = img.naturalHeight || img.height;
      if (!targetWidth || !targetHeight) return;

      if (targetWidth > MAX_EDIT_WIDTH) {
        const ratio = MAX_EDIT_WIDTH / targetWidth;
        targetWidth = MAX_EDIT_WIDTH;
        targetHeight = Math.max(1, Math.round(targetHeight * ratio));
      }

      sourceCanvas.width = targetWidth;
      sourceCanvas.height = targetHeight;
      sourceCtx.clearRect(0, 0, targetWidth, targetHeight);
      sourceCtx.drawImage(img, 0, 0, targetWidth, targetHeight);

      canvas.width = targetWidth;
      canvas.height = targetHeight;
      renderFromSource();

      hasImage = true;
      dirty = false;
      setEditorVisible(true);
    }

    function loadImageFromUrl(url) {
      const img = new Image();
      img.decoding = 'async';
      img.onload = () => loadImage(img);
      img.src = url;
    }

    function loadFromFile(file) {
      if (!file || !file.type.startsWith('image/')) return;
      if (objectUrl) URL.revokeObjectURL(objectUrl);
      objectUrl = URL.createObjectURL(file);
      loadImageFromUrl(objectUrl);
    }

    function applyBlur(x, y, brushSize, strength) {
      const radius = Math.max(1, Math.floor(brushSize / 2));
      const blurRadius = Math.max(1, Math.round(strength / 4));
      const sx = clamp(Math.floor(x - radius - blurRadius), 0, canvas.width - 1);
      const sy = clamp(Math.floor(y - radius - blurRadius), 0, canvas.height - 1);
      const sw = Math.max(1, Math.min(canvas.width - sx, radius * 2 + blurRadius * 2));
      const sh = Math.max(1, Math.min(canvas.height - sy, radius * 2 + blurRadius * 2));

      tempCanvas.width = sw;
      tempCanvas.height = sh;
      tempCtx.clearRect(0, 0, sw, sh);
      tempCtx.drawImage(canvas, sx, sy, sw, sh, 0, 0, sw, sh);

      ctx.save();
      ctx.beginPath();
      ctx.arc(x, y, radius, 0, Math.PI * 2);
      ctx.clip();
      ctx.filter = `blur(${blurRadius}px)`;
      ctx.drawImage(tempCanvas, sx, sy, sw, sh);
      ctx.filter = 'none';
      ctx.restore();
    }

    function applyMosaic(x, y, brushSize, strength) {
      const radius = Math.max(1, Math.floor(brushSize / 2));
      const sx = clamp(Math.floor(x - radius), 0, canvas.width - 1);
      const sy = clamp(Math.floor(y - radius), 0, canvas.height - 1);
      const sw = Math.max(1, Math.min(canvas.width - sx, radius * 2));
      const sh = Math.max(1, Math.min(canvas.height - sy, radius * 2));
      const block = Math.max(2, Math.round(strength / 2));

      const imageData = ctx.getImageData(sx, sy, sw, sh);
      const data = imageData.data;

      for (let yy = 0; yy < sh; yy += block) {
        for (let xx = 0; xx < sw; xx += block) {
          const base = (yy * sw + xx) * 4;
          const r = data[base];
          const g = data[base + 1];
          const b = data[base + 2];
          const a = data[base + 3];
          const yMax = Math.min(yy + block, sh);
          const xMax = Math.min(xx + block, sw);

          for (let y2 = yy; y2 < yMax; y2 += 1) {
            for (let x2 = xx; x2 < xMax; x2 += 1) {
              const i = (y2 * sw + x2) * 4;
              data[i] = r;
              data[i + 1] = g;
              data[i + 2] = b;
              data[i + 3] = a;
            }
          }
        }
      }

      tempCanvas.width = sw;
      tempCanvas.height = sh;
      tempCtx.putImageData(imageData, 0, 0);

      ctx.save();
      ctx.beginPath();
      ctx.arc(x, y, radius, 0, Math.PI * 2);
      ctx.clip();
      ctx.drawImage(tempCanvas, sx, sy, sw, sh);
      ctx.restore();
    }

    function paint(evt) {
      if (!hasImage) return;
      const { x, y } = getCanvasPoint(evt);
      const brushSize = parseInt(brushSizeInput.value, 10) || 90;
      const strength = parseInt(strengthInput.value, 10) || 14;
      if (tool === 'mosaic') applyMosaic(x, y, brushSize, strength);
      else applyBlur(x, y, brushSize, strength);
      dirty = true;
    }

    blurBtn.addEventListener('click', () => setTool('blur'));
    mosaicBtn.addEventListener('click', () => setTool('mosaic'));
    resetBtn.addEventListener('click', () => {
      if (!hasImage) return;
      renderFromSource();
      dirty = false;
    });

    canvas.addEventListener('pointerdown', (evt) => {
      if (!hasImage) return;
      painting = true;
      canvas.setPointerCapture(evt.pointerId);
      paint(evt);
    });
    canvas.addEventListener('pointermove', (evt) => {
      if (!painting) return;
      paint(evt);
    });
    canvas.addEventListener('pointerup', (evt) => {
      if (!painting) return;
      painting = false;
      canvas.releasePointerCapture(evt.pointerId);
    });
    canvas.addEventListener('pointerleave', () => {
      painting = false;
    });

    if (!supportsEditedUpload) {
      setEditorVisible(false);
      editorEmpty.textContent = 'Blur and mosaic tools require a newer browser with file editing support.';
      return;
    }

    imageInput.addEventListener('change', () => {
      const [file] = imageInput.files || [];
      if (file) {
        loadFromFile(file);
      } else if (existingImageUrl) {
        loadImageFromUrl(existingImageUrl);
      } else {
        hasImage = false;
        dirty = false;
        setEditorVisible(false);
      }
    });

    form.addEventListener('submit', (evt) => {
      if (!hasImage || !dirty) return;
      evt.preventDefault();
      canvas.toBlob((blob) => {
        if (!blob) {
          window.alert('Could not apply privacy edits. The original image will be submitted.');
          form.submit();
          return;
        }
        const originalName = (imageInput.files && imageInput.files[0] && imageInput.files[0].name) || 'room-image';
        const baseName = sanitizeFilename(originalName);
        const editedFile = new File([blob], `${baseName}${EDITED_FILE_SUFFIX}.jpg`, { type: 'image/jpeg' });
        const dt = new DataTransfer();
        dt.items.add(editedFile);
        imageInput.files = dt.files;
        form.submit();
      }, 'image/jpeg', OUTPUT_JPEG_QUALITY);
    });

    setTool('blur');
    setEditorVisible(false);
    if (existingImageUrl) loadImageFromUrl(existingImageUrl);
  })();
</script>

<% if (safeRoomImagePath) { %>
<script src="https://cdn.jsdelivr.net/npm/pannellum@2.5.6/build/pannellum.js"></script>
<script>
  const PANORAMA_URL = '/<%= safeRoomImagePath %>';
  const INIT_PITCH   = <%= room.initial_pitch || 0 %>;
  const INIT_YAW     = <%= room.initial_yaw || 0 %>;

  /* ── Initial view picker ──────────────────────────── */
  let previewViewer = null;

  document.getElementById('toggle-preview-btn').addEventListener('click', () => {
    const section = document.getElementById('preview-section');
    if (section.style.display === 'none') {
      section.style.display = 'block';
      if (!previewViewer) {
        previewViewer = pannellum.viewer('pnlm-preview', {
          type: 'equirectangular',
          panorama: PANORAMA_URL,
          pitch: INIT_PITCH,
          yaw: INIT_YAW,
          autoLoad: true,
          showControls: false,
          compass: false,
          mouseZoom: false,
        });
        // overlay crosshair
        const ch = document.createElement('div');
        ch.className = 'pick-crosshair';
        document.getElementById('pnlm-preview').appendChild(ch);
      }
    } else {
      section.style.display = 'none';
    }
  });

  document.getElementById('capture-initial-btn').addEventListener('click', () => {
    if (!previewViewer) return;
    const p = previewViewer.getPitch().toFixed(1);
    const y = previewViewer.getYaw().toFixed(1);
    document.getElementById('initial_pitch').value = p;
    document.getElementById('initial_yaw').value = y;
    document.getElementById('preview-section').style.display = 'none';
  });

  <% if (allRooms.length > 0) { %>
  /* ── Hotspot position picker ──────────────────────── */
  let pickerViewer = null;

  document.getElementById('toggle-picker-btn').addEventListener('click', () => {
    const section = document.getElementById('picker-section');
    if (section.style.display === 'none') {
      section.style.display = 'block';
      if (!pickerViewer) {
        pickerViewer = pannellum.viewer('pnlm-hotspot-picker', {
          type: 'equirectangular',
          panorama: PANORAMA_URL,
          pitch: parseFloat(document.getElementById('hs-pitch').value) || 0,
          yaw: parseFloat(document.getElementById('hs-yaw').value) || 0,
          autoLoad: true,
          showControls: false,
          compass: false,
          mouseZoom: false,
        });
        // overlay crosshair
        const ch = document.createElement('div');
        ch.className = 'pick-crosshair';
        document.getElementById('pnlm-hotspot-picker').appendChild(ch);
      }
    } else {
      section.style.display = 'none';
    }
  });

  document.getElementById('capture-hs-btn').addEventListener('click', () => {
    if (!pickerViewer) return;
    const p = pickerViewer.getPitch().toFixed(1);
    const y = pickerViewer.getYaw().toFixed(1);
    document.getElementById('hs-pitch').value = p;
    document.getElementById('hs-yaw').value = y;
    document.getElementById('picker-section').style.display = 'none';
  });
  <% } %>
</script>
<% } %>

<%- include('../partials/footer', {}) %>
