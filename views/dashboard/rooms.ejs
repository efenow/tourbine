<%- include('../partials/header', { title }) %>
<main class="container py-5">
  <nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
      <li class="breadcrumb-item"><a href="/dashboard/tours/<%= tour.id %>/edit"><%= tour.name %></a></li>
      <li class="breadcrumb-item active">Rooms</li>
    </ol>
  </nav>

  <% const canEdit = currentUser && currentUser.role !== 'viewer'; %>
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="h4 mb-0">Rooms — <%= tour.name %></h2>
    <div class="d-flex gap-2">
      <a href="/tour/<%= tour.slug %>" class="btn btn-outline-success btn-sm" target="_blank"><i class="bi bi-eye"></i> View Tour</a>
      <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-toggle="modal" data-bs-target="#embedModal">
        <i class="bi bi-code-slash"></i> Embed Code
      </button>
      <% if (canEdit) { %>
        <a href="/dashboard/tours/<%= tour.id %>/rooms/new" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg"></i> Add Room</a>
      <% } %>
    </div>
  </div>

  <!-- Embed code modal -->
  <div class="modal fade" id="embedModal" tabindex="-1" aria-labelledby="embedModalLabel" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="embedModalLabel"><i class="bi bi-code-slash"></i> Embed Tour</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <p class="text-muted small mb-2">Copy and paste this code to embed the tour on any website:</p>
          <textarea id="embed-code" class="form-control font-monospace" rows="4" readonly
            style="font-size:0.8rem;resize:none;"></textarea>
          <button class="btn btn-sm btn-outline-primary mt-2" id="copy-embed-btn">
            <i class="bi bi-clipboard"></i> Copy to Clipboard
          </button>
        </div>
      </div>
    </div>
  </div>

  <% if (rooms.length === 0) { %>
    <div class="card text-center py-5">
      <div class="card-body text-muted">
        <i class="bi bi-door-open display-4 mb-3 d-block"></i>
        <p>No rooms yet. <a href="/dashboard/tours/<%= tour.id %>/rooms/new">Add your first room</a>.</p>
      </div>
    </div>
  <% } else { %>
    <div class="card">
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>Order</th>
              <th>Thumbnail</th>
              <th>Name</th>
              <th>Default</th>
              <th>Image</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
            <% for (let i = 0; i < rooms.length; i++) { const room = rooms[i]; %>
              <tr>
                <td style="width:70px;">
                  <div class="d-flex flex-column gap-1">
                    <% if (canEdit) { %>
                      <% if (i > 0) { %>
                        <form action="/dashboard/tours/<%= tour.id %>/rooms/<%= room.id %>/move-up" method="POST" class="d-inline">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                          <button type="submit" class="btn btn-outline-secondary btn-sm py-0 px-1" title="Move up"><i class="bi bi-chevron-up"></i></button>
                        </form>
                      <% } else { %>
                        <button class="btn btn-outline-secondary btn-sm py-0 px-1 invisible" disabled><i class="bi bi-chevron-up"></i></button>
                      <% } %>
                      <% if (i < rooms.length - 1) { %>
                        <form action="/dashboard/tours/<%= tour.id %>/rooms/<%= room.id %>/move-down" method="POST" class="d-inline">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                          <button type="submit" class="btn btn-outline-secondary btn-sm py-0 px-1" title="Move down"><i class="bi bi-chevron-down"></i></button>
                        </form>
                      <% } else { %>
                        <button class="btn btn-outline-secondary btn-sm py-0 px-1 invisible" disabled><i class="bi bi-chevron-down"></i></button>
                      <% } %>
                    <% } else { %>
                      <button class="btn btn-outline-secondary btn-sm py-0 px-1 invisible" disabled><i class="bi bi-chevron-up"></i></button>
                      <button class="btn btn-outline-secondary btn-sm py-0 px-1 invisible" disabled><i class="bi bi-chevron-down"></i></button>
                    <% } %>
                  </div>
                </td>
                <td style="width:80px;">
                  <% if (room.image_path) { %>
                    <img src="/<%= room.image_path %>" style="width:70px;height:45px;object-fit:cover;border-radius:4px;" alt="<%= room.name %>">
                  <% } else { %>
                    <div class="bg-secondary text-white d-flex align-items-center justify-content-center rounded" style="width:70px;height:45px;font-size:0.7rem;">No img</div>
                  <% } %>
                </td>
                <td class="fw-semibold"><%= room.name %></td>
                <td>
                  <% if (room.is_default) { %>
                    <i class="bi bi-star-fill text-warning" title="Default room"></i>
                  <% } else { %>
                    <span class="text-muted">—</span>
                  <% } %>
                </td>
                <td>
                  <% if (room.image_path) { %>
                    <span class="badge bg-success"><i class="bi bi-check"></i> Uploaded</span>
                  <% } else { %>
                    <span class="badge bg-secondary">None</span>
                  <% } %>
                </td>
                <td>
                  <div class="d-flex gap-1 flex-wrap">
                    <% if (canEdit) { %>
                      <a href="/dashboard/tours/<%= tour.id %>/rooms/<%= room.id %>/edit" class="btn btn-outline-secondary btn-sm"><i class="bi bi-pencil"></i> Edit</a>
                      <% if (!room.is_default) { %>
                        <form action="/dashboard/tours/<%= tour.id %>/rooms/<%= room.id %>/set-default" method="POST" class="d-inline">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                          <button type="submit" class="btn btn-outline-warning btn-sm"><i class="bi bi-star"></i> Set Default</button>
                        </form>
                      <% } %>
                      <form action="/dashboard/tours/<%= tour.id %>/rooms/<%= room.id %>?_method=DELETE" method="POST" class="d-inline"
                            onsubmit="return confirm('Delete room &quot;<%= room.name %>&quot;?')">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <button type="submit" class="btn btn-outline-danger btn-sm"><i class="bi bi-trash"></i> Delete</button>
                      </form>
                    <% } else { %>
                      <span class="text-muted small">Read-only</span>
                    <% } %>
                  </div>
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  <% } %>
</main>
<script>
  // Populate embed code textarea with the correct origin
  const embedTextarea = document.getElementById('embed-code');
  if (embedTextarea) {
    const embedUrl = window.location.origin + '/tour/<%= tour.slug %>/embed';
    embedTextarea.value =
      `<iframe\n  src="${embedUrl}"\n  width="100%" height="500"\n  style="border:none;border-radius:8px;"\n  allowfullscreen\n  loading="lazy"></iframe>`;
  }

  const copyBtn = document.getElementById('copy-embed-btn');
  if (copyBtn) {
    copyBtn.addEventListener('click', () => {
      const ta = document.getElementById('embed-code');
      navigator.clipboard.writeText(ta.value).then(() => {
        copyBtn.innerHTML = '<i class="bi bi-check2"></i> Copied!';
        setTimeout(() => { copyBtn.innerHTML = '<i class="bi bi-clipboard"></i> Copy to Clipboard'; }, 2000);
      }).catch(() => {
        ta.select();
        document.execCommand('copy');
      });
    });
  }
</script>
<%- include('../partials/footer', {}) %>
