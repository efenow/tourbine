<%- include('../partials/header', { title }) %>
<main class="container py-5">
  <nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
      <li class="breadcrumb-item"><a href="/dashboard/tours/<%= tour.id %>/edit"><%= tour.name %></a></li>
      <li class="breadcrumb-item active">Rooms</li>
    </ol>
  </nav>

  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="h4 mb-0">Rooms — <%= tour.name %></h2>
    <div class="d-flex gap-2">
      <a href="/tour/<%= tour.slug %>" class="btn btn-outline-success btn-sm" target="_blank"><i class="bi bi-eye"></i> View Tour</a>
      <a href="/dashboard/tours/<%= tour.id %>/rooms/new" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg"></i> Add Room</a>
    </div>
  </div>

  <% if (rooms.length === 0) { %>
    <div class="card text-center py-5">
      <div class="card-body text-muted">
        <i class="bi bi-door-open display-4 mb-3 d-block"></i>
        <p>No rooms yet. <a href="/dashboard/tours/<%= tour.id %>/rooms/new">Add your first room</a>.</p>
      </div>
    </div>
  <% } else { %>
    <div class="card">
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>Thumbnail</th>
              <th>Name</th>
              <th>Default</th>
              <th>Image</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% for (const room of rooms) { %>
              <tr>
                <td style="width:80px;">
                  <% if (room.image_path) { %>
                    <img src="/<%= room.image_path %>" style="width:70px;height:45px;object-fit:cover;border-radius:4px;" alt="<%= room.name %>">
                  <% } else { %>
                    <div class="bg-secondary text-white d-flex align-items-center justify-content-center rounded" style="width:70px;height:45px;font-size:0.7rem;">No img</div>
                  <% } %>
                </td>
                <td class="fw-semibold"><%= room.name %></td>
                <td>
                  <% if (room.is_default) { %>
                    <i class="bi bi-star-fill text-warning" title="Default room"></i>
                  <% } else { %>
                    <span class="text-muted">—</span>
                  <% } %>
                </td>
                <td>
                  <% if (room.image_path) { %>
                    <span class="badge bg-success"><i class="bi bi-check"></i> Uploaded</span>
                  <% } else { %>
                    <span class="badge bg-secondary">None</span>
                  <% } %>
                </td>
                <td>
                  <div class="d-flex gap-1 flex-wrap">
                    <a href="/dashboard/tours/<%= tour.id %>/rooms/<%= room.id %>/edit" class="btn btn-outline-secondary btn-sm"><i class="bi bi-pencil"></i> Edit</a>
                    <% if (!room.is_default) { %>
                      <form action="/dashboard/tours/<%= tour.id %>/rooms/<%= room.id %>/set-default" method="POST" class="d-inline">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <button type="submit" class="btn btn-outline-warning btn-sm"><i class="bi bi-star"></i> Set Default</button>
                      </form>
                    <% } %>
                    <form action="/dashboard/tours/<%= tour.id %>/rooms/<%= room.id %>?_method=DELETE" method="POST" class="d-inline"
                          onsubmit="return confirm('Delete room &quot;<%= room.name %>&quot;?')">
                      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                      <button type="submit" class="btn btn-outline-danger btn-sm"><i class="bi bi-trash"></i> Delete</button>
                    </form>
                  </div>
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  <% } %>
</main>
<%- include('../partials/footer', {}) %>
