<%- include('../partials/header', { title }) %>
<main class="container py-5">
  <div class="dashboard-header d-flex justify-content-between align-items-center mb-4">
    <h1 class="h2 mb-0"><i class="bi bi-grid"></i> Dashboard</h1>
    <a href="/dashboard/tours/new" class="btn btn-primary"><i class="bi bi-plus-lg"></i> New Tour</a>
  </div>

  <div class="row g-3 mb-4">
    <div class="col-sm-6 col-md-3">
      <div class="card stat-card text-center py-3">
        <div class="fs-2 fw-bold text-primary"><%= tours.length %></div>
        <div class="text-muted small">Tours</div>
      </div>
    </div>
    <div class="col-sm-6 col-md-3">
      <div class="card stat-card text-center py-3">
        <div class="fs-2 fw-bold text-primary"><%= totalRooms %></div>
        <div class="text-muted small">Rooms</div>
      </div>
    </div>
  </div>

  <% if (tours.length === 0) { %>
    <div class="card text-center py-5">
      <div class="card-body text-muted">
        <p>No tours yet. <a href="/dashboard/tours/new">Create your first tour</a>.</p>
      </div>
    </div>
  <% } else { %>
    <div class="card">
      <div class="card-header">Tours</div>
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>Name</th>
              <th>Rooms</th>
              <th>Created</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% for (const tour of tours) { %>
              <tr>
                <td>
                  <a href="/tour/<%= tour.slug %>" class="text-decoration-none fw-semibold"><%= tour.name %></a>
                  <% if (tour.description) { %>
                    <div class="text-muted small"><%= tour.description.substring(0, 60) %><%= tour.description.length > 60 ? '…' : '' %></div>
                  <% } %>
                </td>
                <td><%= tour.room_count %></td>
                <td class="text-muted small"><%= new Date(tour.created_at).toLocaleDateString() %></td>
                <td>
                  <div class="d-flex gap-1 flex-wrap">
                    <a href="/dashboard/tours/<%= tour.id %>/edit" class="btn btn-outline-secondary btn-sm"><i class="bi bi-pencil"></i> Edit Info</a>
                    <a href="/dashboard/tours/<%= tour.id %>/rooms" class="btn btn-outline-primary btn-sm"><i class="bi bi-door-open"></i> Rooms</a>
                    <a href="/tour/<%= tour.slug %>" class="btn btn-outline-success btn-sm" target="_blank"><i class="bi bi-eye"></i> View</a>
                    <form action="/dashboard/tours/<%= tour.id %>?_method=DELETE" method="POST" class="d-inline"
                          onsubmit="return confirm('Delete tour &quot;<%= tour.name %>&quot;? This cannot be undone.')">
                      <button type="submit" class="btn btn-outline-danger btn-sm"><i class="bi bi-trash"></i> Delete</button>
                    </form>
                  </div>
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  <% } %>
</main>
<%- include('../partials/footer', {}) %>
